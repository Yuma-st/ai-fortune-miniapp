.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #2D1B4E 0%, #4A2C7A 30%, #F5F0FA 100%);
  padding: 20rpx;
  padding-bottom: 60rpx;
}

/* 顶部标题 */
.header {
  text-align: center;
  padding: 40rpx 0 30rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
  text-shadow: 0 2rpx 10rpx rgba(139, 92, 246, 0.5);
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 10rpx;
}

/* 通用卡片 */
.card {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 25rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #8B5CF6, #A78BFA, #FFD700);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #4A2C7A;
}

/* 性格卡牌 */
.personality-card .card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.tag {
  background: linear-gradient(135deg, #8B5CF6 0%, #A78BFA 100%);
  color: #FFFFFF;
  padding: 8rpx 20rpx;
  border-radius: 25rpx;
  font-size: 24rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #555555;
  line-height: 1.8;
}

/* 爱情观 */
.love-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.love-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.love-label {
  font-size: 26rpx;
  font-weight: bold;
  color: #8B5CF6;
}

.love-text {
  font-size: 28rpx;
  color: #555555;
  line-height: 1.6;
}

/* 理想伴侣 */
.partner-section {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.partner-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding-left: 20rpx;
  border-left: 4rpx solid #FFD700;
}

.partner-label {
  font-size: 24rpx;
  font-weight: bold;
  color: #FFD700;
}

.partner-text {
  font-size: 28rpx;
  color: #555555;
  line-height: 1.6;
}

/* 正缘时机 */
.timing-content {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.timing-main {
  font-size: 30rpx;
  color: #4A2C7A;
  font-weight: bold;
  line-height: 1.5;
}

.signs-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.sign-item {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

/* 爱情建议 */
.advice-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.advice-item {
  display: flex;
  align-items: flex-start;
  gap: 15rpx;
}

.advice-num {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #8B5CF6 0%, #A78BFA 100%);
  color: #FFFFFF;
  border-radius: 50%;
  text-align: center;
  line-height: 44rpx;
  font-size: 24rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.advice-text {
  font-size: 28rpx;
  color: #555555;
  line-height: 1.6;
  flex: 1;
}

/* 操作按钮 */
.actions {
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  width: 90%;
  margin: 0 auto;
  padding: 25rpx 0;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}

.share-btn {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: #4A2C7A;
  box-shadow: 0 10rpx 30rpx rgba(255, 215, 0, 0.3);
}

.again-btn {
  background: rgba(255, 255, 255, 0.9);
  color: #4A2C7A;
  border: 2rpx solid #8B5CF6;
}

.ad-btn {
  background: linear-gradient(135deg, #8B5CF6 0%, #A78BFA 100%);
  color: #FFFFFF;
  box-shadow: 0 10rpx 30rpx rgba(139, 92, 246, 0.3);
}

/* 免责声明 */
.disclaimer {
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 40rpx;
}
