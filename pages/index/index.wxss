.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #2D1B4E 0%, #4A2C7A 50%, #F5F0FA 100%);
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 顶部区域 */
.header {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #FFFFFF;
  text-shadow: 0 2rpx 10rpx rgba(139, 92, 246, 0.5);
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 10rpx;
}

/* 区域标题 */
.section-title {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: bold;
  margin: 30rpx 0 20rpx;
  padding-left: 10rpx;
}

/* 类型选择卡片 */
.type-cards {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.type-card {
  flex: 1;
  margin: 0 8rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 30rpx 15rpx;
  text-align: center;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  transition: all 0.3s ease;
}

.type-card.active {
  background: rgba(255, 255, 255, 0.95);
  border-color: #FFD700;
  box-shadow: 0 10rpx 30rpx rgba(255, 215, 0, 0.3);
}

.type-icon {
  display: block;
  font-size: 56rpx;
  margin-bottom: 10rpx;
}

.type-name {
  display: block;
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: bold;
  margin-bottom: 5rpx;
}

.type-card.active .type-name {
  color: #4A2C7A;
}

.type-desc {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

.type-card.active .type-desc {
  color: #666666;
}

/* 表单区域 */
.form {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #4A2C7A;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.picker {
  background: #F5F0FA;
  border-radius: 12rpx;
  padding: 20rpx 25rpx;
  font-size: 28rpx;
  color: #333333;
}

.gender-select {
  display: flex;
  gap: 20rpx;
}

.gender-btn {
  flex: 1;
  background: #F5F0FA;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666666;
  border: 2rpx solid transparent;
}

.gender-btn.active {
  background: #4A2C7A;
  color: #FFFFFF;
  border-color: #4A2C7A;
}

/* 免费次数提示 */
.free-tips {
  text-align: center;
  font-size: 26rpx;
  color: #FFD700;
  margin: 20rpx 0;
  text-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.3);
}

.free-tips.no-tips {
  color: #FF6B6B;
}

/* 开始按钮 */
.start-btn {
  width: 90%;
  margin: 30rpx auto;
  background: linear-gradient(135deg, #8B5CF6 0%, #A78BFA 100%);
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: bold;
  padding: 25rpx 0;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 10rpx 30rpx rgba(139, 92, 246, 0.4);
}

.start-btn.disabled {
  background: #CCCCCC;
  box-shadow: none;
}

/* 免责声明 */
.disclaimer {
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 30rpx;
}
