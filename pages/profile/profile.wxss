.container {
  min-height: 100vh;
  background: #F5F0FA;
  padding: 20rpx;
  padding-bottom: 60rpx;
}

/* 用户信息头部 */
.profile-header {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #8B5CF6 0%, #A78BFA 100%);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 25rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 25rpx;
}

.avatar-text {
  font-size: 50rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.user-status {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 次数卡片 */
.usage-card {
  display: flex;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 25rpx;
  box-shadow: 0 5rpx 20rpx rgba(0, 0, 0, 0.05);
}

.usage-item {
  flex: 1;
  text-align: center;
}

.usage-num {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #8B5CF6;
  line-height: 1.2;
}

.usage-label {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 5rpx;
}

.usage-divider {
  width: 2rpx;
  background: #EEEEEE;
  margin: 0 20rpx;
}

/* 区域 */
.section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 25rpx;
  margin-bottom: 25rpx;
  box-shadow: 0 5rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #4A2C7A;
}

/* 历史记录 */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #F9F5FF;
  border-radius: 12rpx;
}

.record-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.record-info {
  flex: 1;
}

.record-type {
  display: block;
  font-size: 28rpx;
  color: #4A2C7A;
  font-weight: bold;
  margin-bottom: 5rpx;
}

.record-date {
  display: block;
  font-size: 22rpx;
  color: #999999;
}

.record-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 10rpx;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* 功能列表 */
.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
}

/* 免责声明 */
.disclaimer {
  text-align: center;
  font-size: 22rpx;
  color: #BBBBBB;
  margin-top: 20rpx;
}
