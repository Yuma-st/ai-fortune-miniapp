<view class="container">
  <!-- 用户信息 -->
  <view class="profile-header">
    <view class="avatar">
      <text class="avatar-text">✨</text>
    </view>
    <view class="user-info">
      <text class="user-name">AI 命理用户</text>
      <text class="user-status">探索命理，遇见正缘</text>
    </view>
  </view>

  <!-- 次数卡片 -->
  <view class="usage-card">
    <view class="usage-item">
      <text class="usage-num">{{freeUsesLeft}}</text>
      <text class="usage-label">今日剩余</text>
    </view>
    <view class="usage-divider"></view>
    <view class="usage-item">
      <text class="usage-num">{{totalUsed}}</text>
      <text class="usage-label">累计使用</text>
    </view>
  </view>

  <!-- 历史记录 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">📜 历史记录</text>
    </view>

    <view class="record-list" wx:if="{{records.length > 0}}">
      <view 
        wx:for="{{records}}" 
        wx:key="index" 
        class="record-item"
        bindtap="viewRecord"
        data-record="{{item}}">
        <view class="record-icon">
          <text wx:if="{{item.type === 'bazi'}}">📅</text>
          <text wx:elif="{{item.type === 'xingpan'}}">⭐</text>
          <text wx:else>🔮</text>
        </view>
        <view class="record-info">
          <text class="record-type">
            {{item.type === 'bazi' ? '八字命理' : item.type === 'xingpan' ? '星盘解读' : '塔罗占卜'}}
          </text>
          <text class="record-date">{{item.date}}</text>
        </view>
        <view class="record-arrow">›</view>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <text class="empty-icon">🔮</text>
      <text class="empty-text">暂无历史记录</text>
      <text class="empty-hint">快去首页开始你的第一次命理探索吧</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">⚙️ 功能</text>
    </view>

    <view class="menu-list">
      <view class="menu-item" bindtap="onAbout">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于我们</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onHelp">
        <text class="menu-icon">❓</text>
        <text class="menu-text">使用帮助</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onPrivacy">
        <text class="menu-icon">🔒</text>
        <text class="menu-text">隐私政策</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 免责声明 -->
  <view class="disclaimer">
    本服务仅供娱乐参考，请理性看待
  </view>
</view>
